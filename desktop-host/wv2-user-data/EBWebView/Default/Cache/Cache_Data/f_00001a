async function loadStations() {
    try {
        const res = await fetchRetry('/api/stations', { method: 'GET' }, 2);
        const data = await res.json();
        stationPresets = data.presets || {};
        allStations = sortStationsByPresetOrder(data.stations || [], stationPresets);
        Object.keys(MODULES).forEach((moduleId) => {
            const saved = localStorage.getItem(MODULES[moduleId].stationKey);
            if (!saved) return;
            try {
                const parsed = JSON.parse(saved);
                if (Array.isArray(parsed)) {
                    selectedStationsByModule[moduleId] = new Set(parsed.filter((s) => allStations.includes(s)));
                }
            } catch (_) {}
        });
        // Only default to all stations on very first launch (no localStorage entry)
        if (!localStorage.getItem(MODULES.clca.stationKey) && selectedStationsByModule.clca.size === 0)
            selectedStationsByModule.clca = new Set(allStations);
        renderStationCheckboxes(true);
        updateStatus();
    } catch (e) {
        logToConsole(`Failed to load stations: ${e.message}`, 'error');
    }
}

