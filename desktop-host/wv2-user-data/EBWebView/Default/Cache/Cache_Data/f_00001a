function generateUUID() {
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
        var r = Math.random() * 16 | 0, v = c == 'x' ? r : (r & 0x3 | 0x8);
        return v.toString(16);
    });
}

let currentProgressSource = null;

function setupProgressStream(taskId) {
    if (currentProgressSource) {
        currentProgressSource.close();
    }
    const progressBar = document.getElementById('progress-bar');
    if (progressBar) {
        progressBar.style.width = '0%';
        progressBar.className = 'progress-bar bg-primary';
    }
    
    currentProgressSource = new EventSource('/api/progress?taskId=' + taskId);
    currentProgressSource.onmessage = (e) => {
        try {
            const data = JSON.parse(e.data);
            if (progressBar) {
                progressBar.style.width = Math.max(5, data.percent) + '%';
                if (data.percent >= 100) {
                    progressBar.className = 'progress-bar bg-status-success';
                }
            }
            const stepText = t('step_' + data.stepKey) || data.stepKey;
            setStatus('generating', stepText + ' (' + data.percent + '%)');
        } catch (err) {}
    };
    currentProgressSource.onerror = () => {
        if (currentProgressSource) {
            currentProgressSource.close();
            currentProgressSource = null;
        }
    };
}

